{
  "name": "vrnoponto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "diag": "node scripts/diag.mjs",
    "verify": "npm run lint && npm run build",
    "snapshot": "npm run verify && node scripts/diag.mjs snapshot",
    "supabase:version": "npx supabase --version",
    "supabase:init": "npx supabase init",
    "supabase:link": "npx supabase link --project-ref $SUPABASE_PROJECT_REF",
    "supabase:push": "npx supabase db push",
    "supabase:seed": "npx supabase db execute --file supabase/migrations/0002_seed.sql",
    "supabase:check": "node scripts/supabase-check.mjs",
    "ops:env": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/vrnp-env-local.ps1",
    "ops:supabase": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/vrnp-supabase-apply.ps1",
    "ops:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/vrnp-smoke.ps1",
    "ops:go": "npm run ops:env && npm run supabase:check && npm run ops:supabase && npm run verify && npm run ops:smoke && npm run diag"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}